#!/usr/bin/env bash
# MemoriaServer 初期セットアップ。
# 用途：
#   - 新環境で db migrate → admin bootstrap → デフォルトデバイス登録 を1コマンドで
#   - 出力された ADMIN_KEY / DEVICE_KEY を控えて aituber-kit 等のクライアント設定に使う
#
# 使い方：
#   bin/ms-setup                                    # デフォルト（device "main-pc"）
#   DEVICE_NAME="My Stack-chan" bin/ms-setup        # 別名で登録

set -euo pipefail

cd "$(dirname "$0")/.."

DEVICE_NAME="${DEVICE_NAME:-main-pc}"

echo "==> [1/3] db:migrate"
bin/rails db:migrate

echo ""
echo "==> [2/3] ms:admin:bootstrap"
bin/rails ms:admin:bootstrap

echo ""
echo "==> [3/3] ms:device:register DEVICE_NAME=$DEVICE_NAME"
bin/rails ms:device:register DEVICE_NAME="$DEVICE_NAME"

echo ""
echo "============================================================"
echo "Setup complete."
echo "Server URL : http://localhost:3000"
echo "Admin key  : 上記の ADMIN KEY を控える（運用ツールで使用）"
echo "Device key : 上記の DEVICE KEY を控える（クライアント設定で使用）"
echo "============================================================"
