# Gemini API
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
GEMINI_LIGHT_MODEL=gemini-2.0-flash-lite
GEMINI_THINKING_BUDGET=0

# Vault
VAULT_ROOT=~/memoria-vaults

# Database (WSL2)
# DATABASE_URL=postgres://localhost:5433/memoria_development

# Discord Bot
# DISCORD_BOT_TOKEN=your_bot_token_here
# DISCORD_CHANNEL_ID=your_channel_id_here

# MemoriaServer (MS)
# Redis 接続URL（pub/sub 用）。デフォルト: redis://localhost:6379/0
# MS_REDIS_URL=redis://localhost:6379/0
# APIキーハッシュのペッパー。本番では必ず長いランダム値に変更すること。
# MS_KEY_PEPPER=please-generate-a-long-random-string-for-production
# 使用するアダプタ。memoria_core (default) / http / "MyApp::MyAdapter" 形式のクラス名
# MS_ADAPTER=memoria_core
# HTTPアダプタ使用時の外部エンドポイントURL
# MS_ADAPTER_URL=http://localhost:8080
# MS_ADAPTER_TIMEOUT=120
